# Production environment template for ECS
# Copy to /opt/Palmi/.env and /opt/Palmi/backend/.env
# Fill in all values before deploying

# --- Database ---
DATABASE_URL=postgresql+asyncpg://palmi:YOUR_PASSWORD@postgres:5432/palmi
DATABASE_URL_SYNC=postgresql://palmi:YOUR_PASSWORD@postgres:5432/palmi

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- WeCom (企业微信) ---
WECOM_CORP_ID=
WECOM_TOKEN=
WECOM_SECRET=
WECOM_ENCODING_AES_KEY=
WECOM_AGENT_ID=

# --- LLM (DashScope coding endpoint) ---
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_PRIMARY_MODEL=qwen3-coder-plus
LLM_FALLBACK_API_KEY=

# --- App ---
APP_ENV=production
