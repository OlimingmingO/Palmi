# ============================================================
# Palmi Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://palmi:palmi_secret@localhost:5432/palmi
DATABASE_URL_SYNC=postgresql://palmi:palmi_secret@localhost:5432/palmi

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Enterprise WeChat (WeCom) ---
WECOM_BOT_ID=your-bot-id
WECOM_SECRET=your-secret
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id

# --- LLM ---
LLM_PRIMARY_MODEL=qwen-max
LLM_PRIMARY_API_KEY=your-qwen-api-key
LLM_PRIMARY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK_MODEL=deepseek-v3
LLM_FALLBACK_API_KEY=your-deepseek-api-key
LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1

# --- Embedding ---
EMBEDDING_MODEL=qwen-embedding-v3
EMBEDDING_API_KEY=your-qwen-api-key

# --- Aliyun Voice Call ---
ALIYUN_ACCESS_KEY_ID=your-access-key
ALIYUN_ACCESS_KEY_SECRET=your-access-secret
ALIYUN_VOICE_REGION=cn-shanghai
ALIYUN_TTS_APP_KEY=your-tts-app-key
ALIYUN_ASR_APP_KEY=your-asr-app-key

# --- PKE (Personal Knowledge Engine) ---
PKE_VAULT_ROOT=/data/users
PKE_MAX_RAW_FILES=365
PKE_COMPILE_CRON=0 3 * * *

# --- Phone Call ---
MAX_CALL_DURATION_SEC=1800

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- WeChat Mini-program (Configurator) ---
WECHAT_APP_ID=your-mini-program-appid
WECHAT_APP_SECRET=your-mini-program-secret
